# 复制为 .env 后填写（PowerShell: Copy-Item .env.example .env）
# 或在仓库根目录运行: .\start_bot.ps1

# ─── Telegram（必填，否则 python run.py 会立刻退出）──────────────────────────
# 在 Telegram 里找 @BotFather → /newbot 或已有 bot → API Token
TELEGRAM_BOT_TOKEN=

# 你的 Telegram 用户数字 ID（仅该用户可用 bot）。获取：给 @userinfobot 发消息，或先留空看启动日志
AUTHORIZED_USER_ID=

# ─── Solana 链上监听（聪明钱 / 巨鲸 / TargetWalletMonitor）────────────────────
# 推荐：只填 Helius API Key，config 会自动设置 WSS + HTTP（同一节点，适合 logs_subscribe + get_transaction）
HELIUS_API_KEY=

# 若不用 Helius，可显式写公链或其它供应商（此时可不设 HELIUS_API_KEY）
# ONCHAIN_SOL_WSS=wss://api.mainnet-beta.solana.com
# SOLANA_RPC_HTTP=https://api.mainnet-beta.solana.com

# ─── 可选：仅 SmartMoneyTracker 里拉「顶级钱包」列表会用到 ─────────────────────
# HELIUS_API_KEY 同上即可，无需重复配置
